# -----------------------------------
# Server
# -----------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=*

# -----------------------------------
# MongoDB (default — set DB_PROVIDER=postgres to switch)
# -----------------------------------
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
DB_PROVIDER=mongo

# -----------------------------------
# Supabase Postgres
# Use URL-encoded password if it contains @ # or other special chars
# -----------------------------------
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# -----------------------------------
# JWT Authentication
# -----------------------------------
JWT_KEY=your-secret-key-here
JWT_EXPIRY=7d

# -----------------------------------
# WebSocket Server
# -----------------------------------
WS_PORT=3002
WS_URL=ws://localhost:3002

# -----------------------------------
# Email Service (OTP)
# -----------------------------------
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# -----------------------------------
# URLs
# -----------------------------------
BASE_URL=http://localhost:3001/uploads/
DOMAIN_URL=http://localhost:3000

# -----------------------------------
# RapidAPI — Real-Time Amazon Data (offers)
# -----------------------------------
RAPIDAPI_KEY=
