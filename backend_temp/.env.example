# -----------------------------------
# Server
# -----------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=*

# -----------------------------------
# MongoDB — sole database (Mongoose ORM)
# -----------------------------------
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGO_DB_NAME=test

# -----------------------------------
# JWT Authentication
# -----------------------------------
JWT_KEY=your-secret-key-here
JWT_EXPIRY=7d

# -----------------------------------
# WebSocket Server
# -----------------------------------
WS_PORT=3002
WS_URL=ws://localhost:3002

# -----------------------------------
# Email Service (OTP)
# -----------------------------------
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# -----------------------------------
# Google Sign-In (Web OAuth client ID from Google Cloud Console)
# -----------------------------------
GOOGLE_CLIENT_ID=16052237336-o9pt8bkl1oa0u18o7btqo3q4a0hg1cvq.apps.googleusercontent.com

# -----------------------------------
# URLs (voice/receipt files served at BASE_URL + relative path)
# -----------------------------------
BASE_URL=http://localhost:3001/uploads/
DOMAIN_URL=http://localhost:3000

# -----------------------------------
# RapidAPI — Real-Time Amazon Data (offers / product search)
# Subscribe: https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
# BASIC plan has a monthly request limit — upgrade if offers stop loading
# -----------------------------------
RAPIDAPI_KEY=
